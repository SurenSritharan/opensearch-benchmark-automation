{
  "settings": {
    "index": {
      "number_of_shards": {{ target_index_primary_shards | default(1) }},
      "number_of_replicas": {{ target_index_replica_shards | default(0) }},
      "knn": true
    }
  },
  "mappings": {
    "properties": {
      "passage_id": { "type": "keyword" },
      "text": { "type": "text" },
      "vector": {
        "type": "knn_vector",
        "dimension": {{ target_index_dimension | default(1024) }},
        "method": {
          "name": "{{ method_name | default('disk_ann') }}",
          "space_type": "{{ space_type | default('cosinesimil') }}",
          "engine": "{{ engine | default('jvector') }}",
          "parameters": {
            {%- set comma = joiner(",") %}
            {%- if hnsw_ef_construction is defined and hnsw_ef_construction %}
              {{ comma() }} "ef_construction": {{ hnsw_ef_construction }}
            {%- endif %}
            {%- if hnsw_m is defined and hnsw_m %}
              {{ comma() }} "m": {{ hnsw_m }}
            {%- endif %}
          }
        }
      }
    }
  }
}