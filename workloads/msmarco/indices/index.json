{
  "settings": {
    "index": {
      "number_of_shards": 5,
      "number_of_replicas": 0,
      "knn": true
    }
  },
  "mappings": {
    "properties": {
      "passage_id": { "type": "keyword" },
      "text": { "type": "text" },
      "vector": {
        "type": "knn_vector",
        "dimension": 1024,
        "method": {
          "name": "{{ method_name | default('hnsw') }}",
          "space_type": "{{ space_type | default('cosinesimil') }}",
          "engine": "{{ engine | default('jvector') }}"
        }
      }
    }
  }
}